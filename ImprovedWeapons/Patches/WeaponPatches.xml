<?xml version="1.0" encoding="utf-8" ?>
<!-- 
    Template for adding the tag for a weapon:

    <Operation Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="defName_Here"]/weaponTags</xpath>
        <value>
            <li>slightlyImprovedWeaponsTag</li>
        </value>
    </Operation>
-->

